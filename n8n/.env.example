COMPOSE_PROJECT_NAME=desir-n8n
N8N_IMAGE=docker.n8n.io/n8nio/n8n:stable
POSTGRES_IMAGE=postgres:16-alpine
N8N_DOMAIN=n8n.desirsolutions.com
N8N_HOST=n8n.desirsolutions.com
N8N_PROTOCOL=https
N8N_PORT=5678
N8N_EDITOR_BASE_URL=https://n8n.desirsolutions.com/
WEBHOOK_URL=https://n8n.desirsolutions.com/
N8N_PROXY_HOPS=1
N8N_PATH=/
N8N_RUNNERS_ENABLED=true
N8N_SECURE_COOKIE=true
N8N_USER_MANAGEMENT_JWT_SECRET=replace-with-strong-jwt-secret
N8N_ENCRYPTION_KEY=replace-with-long-random-encryption-key
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_BLOCK_ENV_ACCESS_IN_NODE=true
N8N_BLOCK_FILE_ACCESS_TO_N8N_FILES=true
N8N_LOG_LEVEL=info
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
N8N_TEMPLATES_ENABLED=false
N8N_METRICS=true
N8N_INVITE_LINKS_EMAIL_ONLY=false
N8N_MFA_ENABLED=true
GENERIC_TIMEZONE=America/Los_Angeles
TZ=America/Los_Angeles
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=336
EXECUTIONS_DATA_PRUNE_MAX_COUNT=10000
EXECUTIONS_DATA_PRUNE_HARD_DELETE_INTERVAL=15
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_SUCCESS=none
EXECUTIONS_DATA_SAVE_ON_PROGRESS=false
EXECUTIONS_TIMEOUT=3600
EXECUTIONS_TIMEOUT_MAX=3600
N8N_DEFAULT_BINARY_DATA_MODE=filesystem
N8N_AVAILABLE_BINARY_DATA_MODES=filesystem
N8N_BINARY_DATA_STORAGE_PATH=/home/node/.n8n/binary-data
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=replace-with-postgres-password
DB_POSTGRESDB_SCHEMA=public
# Optional until domain and email are ready:
# N8N_EMAIL_MODE=smtp
# N8N_SMTP_HOST=smtp.example.com
# N8N_SMTP_PORT=587
# N8N_SMTP_USER=smtp-user
# N8N_SMTP_PASS=replace-with-smtp-password
# N8N_SMTP_SENDER=n8n@desirsolutions.com
# N8N_SMTP_SSL=false
# N8N_SMTP_STARTTLS=true
N8N_SKIP_WEBHOOK_DEREGISTRATION_SHUTDOWN=true
N8N_PUSH_BACKEND=websocket
LETSENCRYPT_EMAIL=contact@desirsolutions.com
STACK_NETWORK=platform_edge
POSTGRES_DATA_PATH=/opt/desir/n8n-stack/postgres
N8N_DATA_PATH=/opt/desir/n8n-stack/data
DESIR_CRM_BASE_URL=https://desirsolutions.com
DESIR_CRM_API_KEY=replace-with-existing-crm-automation-api-key
DESIR_APPROVAL_DIGEST_TO=contact@desirsolutions.com
