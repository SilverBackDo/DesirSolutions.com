# Canonical root .dockerignore for Desirtech.
# Scope: root Dockerfile build context only (nginx static site + nginx config).
# CRM app code is kept in this repo but built separately by docker-compose backend service.

# Environment and secrets
.env
.env.*
*.env

# Git
.git
.gitignore

# CRM app code (kept in repo, excluded from frontend image context)
crm-project-Desir-Tech/

# Runtime host assets and ops scripts (not copied into frontend image)
scripts/
certbot/

# Documentation
*.md
DEPLOYMENT-GUIDE.md
LICENSE

# Database dumps
*.sql
*.sql.gz

# OS and IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

# Build artifacts
node_modules/
npm-debug.log*
