# Staging environment template for side-by-side deployment with production.
# Use with:
#   docker compose --env-file .env.staging -p desir-staging \
#     -f docker-compose.staging.yml up -d --build
# Copy to .env.staging and fill real values.
# NEVER commit .env.staging to version control.

# Staging-only host ports
STAGING_HTTP_PORT=8080
STAGING_HTTPS_PORT=8443
STAGING_BACKEND_PORT=18000
STAGING_PGADMIN_PORT=15050

# Database
DB_HOST=db
DB_PORT=5432
DB_NAME=desir_staging
DB_USER=desiruser
DB_PASSWORD=REPLACE_WITH_STAGING_DB_PASSWORD

# Backend app settings
SECRET_KEY=REPLACE_WITH_STAGING_APP_SECRET
AUTH_JWT_SECRET=REPLACE_WITH_STAGING_JWT_SECRET
AUTOMATION_API_KEY=REPLACE_WITH_STAGING_AUTOMATION_API_KEY
ALLOWED_ORIGINS=https://staging.desirsolutions.com,https://localhost:8443
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXP_MINUTES=480
CRM_ADMIN_USERNAME=staging-admin
CRM_ADMIN_PASSWORD=REPLACE_WITH_STAGING_ADMIN_PASSWORD
# Optional named operators:
# CRM_AUTH_USERS=[{"username":"ops-lead","role":"approver","password":"REPLACE_WITH_STAGING_PASSWORD"},{"username":"finance-lead","role":"finance","password":"REPLACE_WITH_STAGING_PASSWORD"}]

# Backend runtime mode
ENV=staging
DEBUG=false

# AI Factory
AI_FACTORY_PRIMARY_PROVIDER=openai
AI_FACTORY_REQUIRE_HUMAN_APPROVAL=true
AI_FACTORY_QUEUE_NAME=ai_factory
AI_FACTORY_REDIS_URL=redis://redis:6379/0
AI_FACTORY_QUEUE_RECLAIM_IDLE_MS=300000
AI_OPENAI_MODEL=gpt-5.4-mini
AI_ANTHROPIC_MODEL=claude-sonnet-4-6
AI_MODEL_PRICING_JSON={"gpt-5.4-mini":{"input_per_1m_tokens_usd":"0.75","output_per_1m_tokens_usd":"4.50"},"claude-sonnet-4-6":{"input_per_1m_tokens_usd":"3.00","output_per_1m_tokens_usd":"15.00"}}
AI_COST_ALERT_PER_RUN_USD=0.02
AI_COST_ALERT_DAILY_USD=0.50
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CONTACT_NOTIFICATION_WEBHOOK_URL=
# Example:
# CONTACT_NOTIFICATION_WEBHOOK_URL=https://n8n.staging.desirsolutions.com/webhook/crm/contact-notification
CONTACT_SUBMISSION_RATE_LIMIT_WINDOW_MINUTES=15
CONTACT_SUBMISSION_RATE_LIMIT_MAX=5
OPERATIONS_ALERT_WEBHOOK_URL=
OPERATIONS_ALERT_MIN_SEVERITY=medium
OPERATIONS_ALERT_TIMEOUT_SECONDS=5
OPERATIONS_ALERT_ENABLED_ENVIRONMENTS=production,staging
OPERATIONS_ALERT_NOTIFY_UNHANDLED_EXCEPTIONS=true
OTEL_ENABLED=true
OTEL_SERVICE_NAME=desirtech-backend-staging
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
# Re-verify these rates against official provider pricing before staging/production promotion.

# Backup / restore
BACKUP_DIR=/home/opc/backups-staging
BACKUP_KEEP_DAYS=7
BACKUP_OFFSITE_SYNC_COMMAND=

# pgAdmin
PGADMIN_DEFAULT_EMAIL=staging-admin@desirsolutions.com
PGADMIN_DEFAULT_PASSWORD=REPLACE_WITH_STAGING_PGADMIN_PASSWORD
