#!/usr/bin/env bash
set -euo pipefail

URL="{{ n8n_healthcheck_url }}"

curl --fail --silent --show-error --location "$URL" >/dev/null
docker inspect -f '{{ "{{.State.Health.Status}}" }}' {{ n8n_project_name }} | grep -q healthy
docker inspect -f '{{ "{{.State.Health.Status}}" }}' {{ n8n_project_name }}-postgres | grep -q healthy

echo "n8n health checks passed"
