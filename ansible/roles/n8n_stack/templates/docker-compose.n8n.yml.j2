name: {{ n8n_project_name }}

services:
  postgres:
    image: ${POSTGRES_IMAGE}
    container_name: {{ n8n_project_name }}-postgres
    restart: unless-stopped
    environment:
      POSTGRES_DB: ${DB_POSTGRESDB_DATABASE}
      POSTGRES_USER: ${DB_POSTGRESDB_USER}
      POSTGRES_PASSWORD: ${DB_POSTGRESDB_PASSWORD}
    volumes:
      - ${POSTGRES_DATA_PATH}:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_POSTGRESDB_USER} -d ${DB_POSTGRESDB_DATABASE}"]
      interval: 10s
      timeout: 5s
      retries: 6
      start_period: 15s
    networks:
      - internal

  n8n:
    image: ${N8N_IMAGE}
    container_name: {{ n8n_project_name }}
    init: true
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
    env_file:
      - ./config/n8n.env
    user: "{{ n8n_user_uid }}:{{ n8n_user_gid }}"
    volumes:
      - ${N8N_DATA_PATH}:/home/node/.n8n
    healthcheck:
      test: ["CMD-SHELL", "wget --no-verbose --tries=1 --spider http://127.0.0.1:5678/healthz || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 40s
    labels:
      - traefik.enable=true
      - traefik.docker.network=${STACK_NETWORK}
      - traefik.http.routers.n8n.rule=Host(`${N8N_DOMAIN}`)
      - traefik.http.routers.n8n.entrypoints=websecure
      - traefik.http.routers.n8n.tls.certresolver=letsencrypt
      - traefik.http.routers.n8n.middlewares=n8n-security
      - traefik.http.services.n8n.loadbalancer.server.port=5678
      - traefik.http.middlewares.n8n-security.headers.contentTypeNosniff=true
      - traefik.http.middlewares.n8n-security.headers.browserXssFilter=true
      - traefik.http.middlewares.n8n-security.headers.frameDeny=true
      - traefik.http.middlewares.n8n-security.headers.forceSTSHeader=true
      - traefik.http.middlewares.n8n-security.headers.stsSeconds=31536000
      - traefik.http.middlewares.n8n-security.headers.stsIncludeSubdomains=true
      - traefik.http.middlewares.n8n-security.headers.stsPreload=true
      - traefik.http.middlewares.n8n-security.headers.referrerPolicy=strict-origin-when-cross-origin
      - traefik.http.middlewares.n8n-security.headers.permissionsPolicy=accelerometer=(),camera=(),geolocation=(),microphone=(),payment=(),usb=()
    networks:
      - internal
      - edge

networks:
  internal:
    driver: bridge
  edge:
    external: true
    name: ${STACK_NETWORK}
