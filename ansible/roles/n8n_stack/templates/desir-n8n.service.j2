[Unit]
Description=Desir Solutions n8n stack
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory={{ n8n_stack_root }}
ExecStart=/usr/bin/docker compose --env-file {{ n8n_stack_root }}/config/n8n.env -f {{ n8n_stack_root }}/docker-compose.yml up -d
ExecStop=/usr/bin/docker compose --env-file {{ n8n_stack_root }}/config/n8n.env -f {{ n8n_stack_root }}/docker-compose.yml down
TimeoutStartSec=180
TimeoutStopSec=120

[Install]
WantedBy=multi-user.target
