# Set a live intake endpoint before launch.
# Example:
# VITE_CONTACT_ENDPOINT=https://crm.desirsolutions.com/api/contact/
VITE_CONTACT_ENDPOINT=
DESIR_WEBSITE_IMAGE=ghcr.io/silverbackdo/desirsolutions-website:latest
DESIR_WEBSITE_PORT=80
# If the intake API is routed behind the same host, set:
# VITE_CONTACT_ENDPOINT=/api/contact
