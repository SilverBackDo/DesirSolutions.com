# Canonical root environment template for Desirtech.
# Used by root docker-compose services: db, backend (via env_file), and pgadmin.
# Copy to .env in the repository root and fill real values.
# NEVER commit .env to version control.

# Database (shared by db and backend)
DB_HOST=db
DB_PORT=5432
DB_NAME=desir
DB_USER=desiruser
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Backend app settings
SECRET_KEY=REPLACE_WITH_RANDOM_SECRET
AUTH_JWT_SECRET=REPLACE_WITH_DISTINCT_RANDOM_JWT_SECRET
AUTOMATION_API_KEY=REPLACE_WITH_SERVICE_API_KEY
ALLOWED_ORIGINS=https://desirsolutions.com,https://www.desirsolutions.com
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXP_MINUTES=480
CRM_ADMIN_USERNAME=admin
CRM_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
# Optional multi-user registry:
# CRM_AUTH_USERS=[{"username":"ops","role":"approver","password":"REPLACE_WITH_STRONG_PASSWORD"},{"username":"finance","role":"finance","password":"REPLACE_WITH_STRONG_PASSWORD"},{"username":"viewer","role":"viewer","password":"REPLACE_WITH_STRONG_PASSWORD"}]
# Optional advanced alternative:
# CRM_ADMIN_PASSWORD_HASH=REPLACE_WITH_BCRYPT_HASH
# (requires compatible passlib/bcrypt versions for verification)

# Backend runtime mode
ENV=production
DEBUG=false

# AI Factory
AI_FACTORY_PRIMARY_PROVIDER=openai
AI_FACTORY_REQUIRE_HUMAN_APPROVAL=true
AI_FACTORY_QUEUE_NAME=ai_factory
AI_FACTORY_REDIS_URL=redis://redis:6379/0
AI_FACTORY_QUEUE_RECLAIM_IDLE_MS=300000
AI_OPENAI_MODEL=gpt-5.4-mini
AI_ANTHROPIC_MODEL=claude-sonnet-4-6
AI_MODEL_PRICING_JSON={"gpt-5.4-mini":{"input_per_1m_tokens_usd":"0.75","output_per_1m_tokens_usd":"4.50"},"claude-sonnet-4-6":{"input_per_1m_tokens_usd":"3.00","output_per_1m_tokens_usd":"15.00"}}
AI_COST_ALERT_PER_RUN_USD=0.02
AI_COST_ALERT_DAILY_USD=0.50
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CONTACT_NOTIFICATION_WEBHOOK_URL=
# Example:
# CONTACT_NOTIFICATION_WEBHOOK_URL=https://n8n.desirsolutions.com/webhook/crm/contact-notification
CONTACT_SUBMISSION_RATE_LIMIT_WINDOW_MINUTES=15
CONTACT_SUBMISSION_RATE_LIMIT_MAX=5
OPERATIONS_ALERT_WEBHOOK_URL=
OPERATIONS_ALERT_MIN_SEVERITY=high
OPERATIONS_ALERT_TIMEOUT_SECONDS=5
OPERATIONS_ALERT_ENABLED_ENVIRONMENTS=production,staging
OPERATIONS_ALERT_NOTIFY_UNHANDLED_EXCEPTIONS=true
OTEL_ENABLED=true
OTEL_SERVICE_NAME=desirtech-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
# Re-verify these rates against official provider pricing before production promotion.

# Backup / restore
BACKUP_DIR=/home/opc/backups
BACKUP_KEEP_DAYS=14
# Optional: command run after each successful backup. Example:
# BACKUP_OFFSITE_SYNC_COMMAND=rclone copy "$BACKUP_FILE_PATH" remote:desir-backups/ && rclone copy "$BACKUP_CHECKSUM_PATH" remote:desir-backups/ && rclone copy "$BACKUP_MANIFEST_PATH" remote:desir-backups/
BACKUP_OFFSITE_SYNC_COMMAND=

# pgAdmin local access (required by compose)
PGADMIN_DEFAULT_EMAIL=admin@desirsolutions.com
PGADMIN_DEFAULT_PASSWORD=REPLACE_WITH_STRONG_PGADMIN_PASSWORD

# Note:
# crm-project-Desir-Tech/backend/.env.example is for standalone backend-only dev.
