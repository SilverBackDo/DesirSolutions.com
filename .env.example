# Desir Solutions - Environment Variables
# Copy this file to .env and fill in real values before deploying.
# NEVER commit .env to version control.

# ─── Database ───
DB_HOST=db
DB_PORT=5432
DB_NAME=desir
DB_USER=desiruser
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ─── App ───
SECRET_KEY=REPLACE_WITH_RANDOM_SECRET
ALLOWED_ORIGINS=https://desirsolutions.com,https://www.desirsolutions.com

# ─── Environment ───
ENV=production
DEBUG=false
