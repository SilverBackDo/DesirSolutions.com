# OCI authentication

region            = "us-phoenix-1"
tenancy_ocid      = "ocid1.tenancy.oc1..replace_me"
compartment_ocid  = "ocid1.compartment.oc1..replace_me"
user_ocid         = "ocid1.user.oc1..replace_me"
fingerprint       = "aa:bb:cc:dd:ee:ff"
private_key_path  = "C:/Users/your-user/.oci/oci_api_key.pem"
ssh_public_key    = "ssh-ed25519 AAAA... replace_me"
ssh_allowed_cidrs = ["203.0.113.10/32"] # replace with approved admin IPs or leave empty when using OCI Bastion

# Platform repository and first-boot deploy settings

platform_repo_url       = "https://github.com/SilverBackDo/DesirSolutions.com.git"
platform_repo_ref       = "main"
letsencrypt_email       = "contact@example.com"
desirsolutions_domain    = "desirsolutions.com"
desirsolutions_image     = "ghcr.io/silverbackdo/desirsolutions-website:latest"

# Optional explicit reuse of existing infrastructure. Comment out when you want
# Terraform to discover by display name and create missing resources.

# existing_vcn_id              = "ocid1.vcn.oc1..replace_me"
# existing_subnet_id           = "ocid1.subnet.oc1..replace_me"
# existing_internet_gateway_id = "ocid1.internetgateway.oc1..replace_me"
# existing_route_table_id      = "ocid1.routetable.oc1..replace_me"
# existing_security_list_id    = "ocid1.securitylist.oc1..replace_me"
# existing_instance_id         = "ocid1.instance.oc1..replace_me"
