# ─── Database ───
DB_HOST=db
DB_PORT=5432
DB_NAME=crm
DB_USER=crmuser
DB_PASSWORD=changeme_use_strong_password

# ─── App ───
SECRET_KEY=changeme_generate_a_random_secret
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXP_MINUTES=480
CRM_ADMIN_USERNAME=admin
CRM_ADMIN_PASSWORD=changeme_strong_password
# Optional advanced alternative:
# CRM_ADMIN_PASSWORD_HASH=$2b$12$REPLACE_WITH_BCRYPT_HASH
# (requires compatible passlib/bcrypt versions for verification)

# ─── Environment ───
ENV=development
DEBUG=true
